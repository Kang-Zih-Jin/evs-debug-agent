{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowAccountPrincipalsToAssume",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::ACCOUNT_ID:root"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalAccount": "ACCOUNT_ID"
        }
      }
    }
  ]
}
